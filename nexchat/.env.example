#  NexChat environment variables 
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

#  Django 
DJANGO_ENV=dev                          # dev | prod
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True                              # False in prod
ALLOWED_HOSTS=*                         # comma-separated in prod, e.g. nexchat.example.com

#  MySQL (prod only) 
MYSQL_DB=nexchat
MYSQL_USER=nexchat
MYSQL_PASSWORD=strongpassword
MYSQL_ROOT_PASSWORD=strongrootpassword
MYSQL_HOST=db                           # service name in docker-compose; or hostname
MYSQL_PORT=3306

#  Redis (prod only) 
REDIS_HOST=redis                        # service name in docker-compose; or hostname

#  CORS (prod only) 
# comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://nexchat.example.com

#  App settings 
MESSAGE_PAGE_SIZE=50
